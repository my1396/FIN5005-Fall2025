```{r}
#| results: asis
#| echo: false
suppressPackageStartupMessages({library(stargazer); library(sandwich); library(tidyverse)})
cas <- read_csv("https://raw.githubusercontent.com/my1396/FIN5005-Fall2025/refs/heads/main/data/CASchools_test_score.csv", col_types=cols(county=col_factor(),grades=col_factor()))
cas <- cas %>% mutate(TestScore=(read+math)/2, STR=students/teachers)
s1<-lm(TestScore~STR,cas);s2<-lm(TestScore~STR+english,cas);s3<-lm(TestScore~STR+english+lunch,cas)
stargazer(s1,s2,s3,type="latex",digits=3,header=FALSE,float=FALSE,font.size="small",column.sep.width="1pt")
```

